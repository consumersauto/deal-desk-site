{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "deal-desk-site",
  "compatibility_date": "2026-07-03",
  "main": "worker.js",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"]
  },
  "compatibility_flags": [
    "nodejs_compat"
"kv_namespaces": [
    {
      "binding": "DEAL_DESK_KV",
      "id": "a118d7adb5cf434d84fce34b2ae8ba93"
    }
  ]
}
